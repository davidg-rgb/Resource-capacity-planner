    "ag-grid-react": "^35.2.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "flags": "^4.0.5",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
